# Copy this file to ".env" and fill in only the keys you have.
# EVERY key here is OPTIONAL — the tool crawls the public web with zero keys.
#
#     Copy-Item config.example.env .env      (PowerShell)
#
# ---------------------------------------------------------------------------
# SEARCH PROVIDERS  — enable automated `discover`. Pick ONE.
# ---------------------------------------------------------------------------

# SerpAPI — easiest to set up.  https://serpapi.com
#   Free: 100 searches/mo. Paid: ~US$75/mo for 5,000 searches.
SERPAPI_API_KEY=

# Google Programmable Search (Custom Search JSON API)
#   https://developers.google.com/custom-search/v1/overview
#   Free: 100 queries/day, then US$5 / 1,000 queries.
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# Bing Web Search (Azure Cognitive Services)
BING_SEARCH_API_KEY=

# ---------------------------------------------------------------------------
# EMAIL ENRICHMENT (optional) — `enrich` command.
# ---------------------------------------------------------------------------

# Hunter.io domain search.  https://hunter.io
#   Free: 25 searches/mo. Paid from ~US$34/mo.
HUNTER_API_KEY=

# ---------------------------------------------------------------------------
# CRAWLER POLITENESS
# ---------------------------------------------------------------------------
CRAWL_DELAY_SECONDS=2
CRAWL_TIMEOUT=15
CRAWL_USER_AGENT=OT-Prospector/1.0 (+B2B research bot; respects robots.txt)
